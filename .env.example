# ─────────────────────────────────────────────
# PORTAFOLIO FOTOGRÁFICO — Variables de Entorno
# Copiá este archivo como .env y completá los valores
# NUNCA commitees el archivo .env real
# ─────────────────────────────────────────────

# Admin — hash SHA-256 de tu contraseña
# Generá el hash con: echo -n "TuContraseña" | shasum -a 256
VITE_ADMIN_PASSWORD_HASH=

# Emails autorizados (separados por coma, sin espacios)
VITE_AUTHORIZED_EMAILS=

# Google OAuth (dormido — completar solo si se reactiva)
VITE_GOOGLE_CLIENT_ID=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Gemini AI (opcional — para análisis editorial de fotos)
# Obtener en: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# EmailJS (opcional — para formulario de contacto y notificaciones de comentarios)
# Crear cuenta en: https://www.emailjs.com
# Service ID: Panel > Email Services
# Template IDs: Panel > Email Templates (crear uno para contacto y otro para comentarios)
# Public Key: Panel > Account > Public Key
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_CONTACT=
VITE_EMAILJS_TEMPLATE_COMMENT=
VITE_EMAILJS_PUBLIC_KEY=
